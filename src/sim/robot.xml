<mujoco model="my_robot">
  <compiler angle="radian" meshdir="meshes"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>
  <size njmax="2000" nconmax="2000"/>

  <option timestep="0.005" gravity="0 0 -9.81"/>

  <default>
    <joint limited="true" damping="0.5" armature="0.01"/>
    <geom contype="1" conaffinity="1" friction="1 0.1 0.1" solref="0.01 1" solimp="0.9 0.95 0.001"/>
  </default>

  <asset>
    <!-- all meshes are mm in STL -> scale 0.001 to meters -->
    <mesh name="base_mesh"     file="base.stl"           scale="0.001 0.001 0.001"/>
    <mesh name="rs02_mesh"     file="RS02(0.0.0).stl"    scale="0.001 0.001 0.001"/>
    <mesh name="rs03_mesh"     file="RS03(0.0.0).stl"    scale="0.001 0.001 0.001"/>
    <mesh name="joint1_mesh"   file="joint1.stl"         scale="0.001 0.001 0.001"/>
    <mesh name="link1_1_mesh"  file="link1_1.stl"        scale="0.001 0.001 0.001"/>
    <mesh name="link1_2_mesh"  file="link1_2.stl"        scale="0.001 0.001 0.001"/>
    <mesh name="link1_3_mesh"  file="link1_3.stl"        scale="0.001 0.001 0.001"/>
    <mesh name="joint2_mesh"   file="joint2.stl"         scale="0.001 0.001 0.001"/>
    <mesh name="link2_1_mesh"  file="link2_1.stl"        scale="0.001 0.001 0.001"/>
    <mesh name="link2_2_mesh"  file="link2_2.stl"        scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <!-- base -->
    <body name="base" pos="0 0 0">
      <!-- Fusion COM: (0.0, 0.0, 42.4281) mm -->
      <inertial pos="0 0 0.0424281"
                mass="0.398399734"
                fullinertia="0.001218907079 0.001185493046 0.001557694961 3.8269e-08 -5e-12 -1e-12"/>
      <geom type="mesh" mesh="base_mesh"/>

      <!-- m1: fixed base -> rs02_1 at xyz="0 0 0.1015" -->
      <body name="rs02_1" pos="0 0 0.1015">
        <inertial pos="0 0 0.027"
                  mass="0.405"
                  fullinertia="2.12716e-04 2.12716e-04 3.11964e-04 0 0 0"/>
        <geom type="mesh" mesh="rs02_mesh"/>

        <!-- j1: revolute about z, range [-pi, pi] -->
        <body name="joint1" pos="0 0 0">
          <joint name="j1" type="hinge" axis="0 0 -1" range="-3.14159 3.14159"/>
          <!-- Fusion COM: (0.0095, -15.6598, 56.1135) mm -->
          <inertial pos="0.0000095 -0.0156598 0.0561135"
                    mass="0.293398076"
                    fullinertia="0.000896395761 0.001110242191 0.000865240118 -8.1531e-08 5.2379e-08 -0.000147190496"/>
          <geom type="mesh" mesh="joint1_mesh"/>

          <!-- m2: fixed joint1 -> rs03 at xyz="0 -0.0637 0.068" rpy="1.5708 0 0"
               rpy(roll=+90deg) => quat(w,x,y,z) = (0.7071, 0.7071, 0, 0)
          -->
          <body name="rs03" pos="0 -0.0637 0.068" quat="0.70710678 0.70710678 0 0">
            <inertial pos="0 0 0.035"
                      mass="0.88"
                      fullinertia="8.31820e-04 8.31820e-04 1.23596e-03 0 0 0"/>
            <geom type="mesh" mesh="rs03_mesh"/>

            <!-- j2: revolute about z, range [-2.5, 2.5] -->
            <body name="link1_1" pos="0 0 0">
              <joint name="j2" type="hinge" axis="0 0 -1" range="-2.5 2.5"/>
              <!-- Fusion COM: (0.0, 23.1488, 44.0015) mm -->
              <inertial pos="0 0.0231488 0.0440015"
                        mass="0.319496008"
                        fullinertia="0.000638154136 0.000425282889 0.000647113353 -3.1e-11 1.09e-10 0.000120587347"/>
              <geom type="mesh" mesh="link1_1_mesh"/>

              <!-- j2_2: fixed link1_1 -> link1_2 at xyz="0 0.05 0.05715" rpy="-1.5708 0 0"
                   roll=-90deg => quat=(0.7071, -0.7071, 0, 0)
              -->
              <body name="link1_2" pos="0 0.05 0.05715" quat="0.70710678 -0.70710678 0 0">
                <!-- Fusion COM: (0.0, 0.0, 150.0) mm -->
                <inertial pos="0 0 0.15"
                          mass="0.508299975"
                          fullinertia="0.003890759307 0.003890759307 0.000157018996 0 0 0"/>
                <geom type="mesh" mesh="link1_2_mesh"/>

                <!-- j2_3: fixed link1_2 -> link1_3 at xyz="0 0 0.3" -->
                <body name="link1_3" pos="0 0 0.3">
                  <!-- Fusion COM: (0.0002, 15.5124, 33.9681) mm -->
                  <inertial pos="0.0000002 0.0155124 0.0339681"
                            mass="0.279149934"
                            fullinertia="0.000661231823 0.000687897169 0.000472960204 -1.55e-09 1.529e-09 0.000125413257"/>
                  <geom type="mesh" mesh="link1_3_mesh"/>

                  <!-- m3: fixed link1_3 -> rs02_2 at xyz="0 0.06585 0.050" rpy="-1.5708 0 0" -->
                  <body name="rs02_2" pos="0 0.06585 0.050" quat="0.70710678 -0.70710678 0 0">
                    <inertial pos="0 0 0.027"
                              mass="0.405"
                              fullinertia="2.12716e-04 2.12716e-04 3.11964e-04 0 0 0"/>
                    <geom type="mesh" mesh="rs02_mesh"/>

                    <!-- j3 -->
                    <body name="joint2" pos="0 0 0">
                      <joint name="j3" type="hinge" axis="0 0 -1" range="-3.14159 3.14159"/>
                      <!-- Fusion COM: (0.0027, -11.3791, 42.1733) mm -->
                      <inertial pos="0.0000027 -0.0113791 0.0421733"
                                mass="0.169648237"
                                fullinertia="0.000296367505 0.000366233598 0.000291288551 -7.634e-09 3.6434e-08 -0.000048442986"/>
                      <geom type="mesh" mesh="joint2_mesh"/>

                      <!-- m4: fixed joint2 -> rs02_3 at xyz="0 -0.0502 0.055" rpy="1.5708 0 0" -->
                      <body name="rs02_3" pos="0 -0.0502 0.055" quat="0.70710678 0.70710678 0 0">
                        <inertial pos="0 0 0.027"
                                  mass="0.405"
                                  fullinertia="2.12716e-04 2.12716e-04 3.11964e-04 0 0 0"/>
                        <geom type="mesh" mesh="rs02_mesh"/>

                        <!-- j4 -->
                        <body name="link2_1" pos="0 0 0">
                          <joint name="j4" type="hinge" axis="0 0 -1" range="-3.14159 3.14159"/>
                          <!-- Fusion COM: (-0.4642, -0.5063, 38.0142) mm -->
                          <inertial pos="-0.0004642 -0.0005063 0.0380142"
                                    mass="0.188800061"
                                    fullinertia="0.000146197470 0.000146205177 0.000161370291 -4.3751e-08 -0.000001488595 -0.000000892060"/>
                          <geom type="mesh" mesh="link2_1_mesh"/>

                          <body name="link2_2" pos="0 0 0.035">
                            <!-- Fusion COM: (0.0, 0.0, 115.0) mm -->
                            <inertial pos="0 0 0.115"
                                      mass="0.170500037"
                                      fullinertia="0.000759754048 0.000759754048 0.000052564816 0 0 0"/>
                            <geom type="mesh" mesh="link2_2_mesh"/>
                          </body>
                        </body>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- RS02 joints: rated 6 Nm, peak 17 Nm -->
    <motor name="a_j1" joint="j1"
           gear="1"
           ctrllimited="true" ctrlrange="-6 6"
           forcelimited="true" forcerange="-17 17"/>

    <!-- RS03 joint: rated 20 Nm, peak(limit) 60 Nm -->
    <motor name="a_j2" joint="j2"
           gear="1"
           ctrllimited="true" ctrlrange="-20 20"
           forcelimited="true" forcerange="-60 60"/>

    <!-- RS02 joints -->
    <motor name="a_j3" joint="j3"
           gear="1"
           ctrllimited="true" ctrlrange="-6 6"
           forcelimited="true" forcerange="-17 17"/>

    <motor name="a_j4" joint="j4"
           gear="1"
           ctrllimited="true" ctrlrange="-6 6"
           forcelimited="true" forcerange="-17 17"/>
  </actuator>

</mujoco>
